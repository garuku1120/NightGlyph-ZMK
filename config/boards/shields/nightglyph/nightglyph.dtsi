#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/gpio/gpio.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    /*
     * 合体マトリクス変換（ZMK Studio対応）
     * 左=列0-5、右=列6-11。右側overlayで col-offset=6 を付ける。
     * 右半分は物理列が反転（COL5=内側→列6側、COL0=外側→列11側）なので
     * 右側のマップを RC(r,11)→RC(r,6) の逆順で記述して整合。
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <5>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)   RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)   RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)   RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)   RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7) RC(3,6)
            RC(4,0) RC(4,1) RC(4,2)                           RC(4,8)  RC(4,7)  RC(4,6)
        >;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "NightGlyph";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys  /* w h x y rot rx ry (centi-units) */
            = <&key_physical_attrs 100 100    0   26 0 0 0>
            , <&key_physical_attrs 100 100  100   26 0 0 0>
            , <&key_physical_attrs 100 100  200    8 0 0 0>
            , <&key_physical_attrs 100 100  300    0 0 0 0>
            , <&key_physical_attrs 100 100  400   13 0 0 0>
            , <&key_physical_attrs 100 100  500   26 0 0 0>
            , <&key_physical_attrs 100 100  700   26 0 0 0>
            , <&key_physical_attrs 100 100  800   13 0 0 0>
            , <&key_physical_attrs 100 100  900    0 0 0 0>
            , <&key_physical_attrs 100 100 1000    8 0 0 0>
            , <&key_physical_attrs 100 100 1100   26 0 0 0>
            , <&key_physical_attrs 100 100 1200   26 0 0 0>

            , <&key_physical_attrs 100 100    0  126 0 0 0>
            , <&key_physical_attrs 100 100  100  126 0 0 0>
            , <&key_physical_attrs 100 100  200  108 0 0 0>
            , <&key_physical_attrs 100 100  300  100 0 0 0>
            , <&key_physical_attrs 100 100  400  113 0 0 0>
            , <&key_physical_attrs 100 100  500  126 0 0 0>
            , <&key_physical_attrs 100 100  700  126 0 0 0>
            , <&key_physical_attrs 100 100  800  113 0 0 0>
            , <&key_physical_attrs 100 100  900  100 0 0 0>
            , <&key_physical_attrs 100 100 1000  108 0 0 0>
            , <&key_physical_attrs 100 100 1100  126 0 0 0>
            , <&key_physical_attrs 100 100 1200  126 0 0 0>

            , <&key_physical_attrs 100 100    0  226 0 0 0>
            , <&key_physical_attrs 100 100  100  226 0 0 0>
            , <&key_physical_attrs 100 100  200  208 0 0 0>
            , <&key_physical_attrs 100 100  300  200 0 0 0>
            , <&key_physical_attrs 100 100  400  213 0 0 0>
            , <&key_physical_attrs 100 100  500  226 0 0 0>
            , <&key_physical_attrs 100 100  700  226 0 0 0>
            , <&key_physical_attrs 100 100  800  213 0 0 0>
            , <&key_physical_attrs 100 100  900  200 0 0 0>
            , <&key_physical_attrs 100 100 1000  208 0 0 0>
            , <&key_physical_attrs 100 100 1100  226 0 0 0>
            , <&key_physical_attrs 100 100 1200  226 0 0 0>

            , <&key_physical_attrs 100 100    0  326 0 0 0>
            , <&key_physical_attrs 100 100  100  326 0 0 0>
            , <&key_physical_attrs 100 100  200  308 0 0 0>
            , <&key_physical_attrs 100 100  300  300 0 0 0>
            , <&key_physical_attrs 100 100  400  313 0 0 0>
            , <&key_physical_attrs 100 100  500  326 0 0 0>
            , <&key_physical_attrs 100 100  700  326 0 0 0>
            , <&key_physical_attrs 100 100  800  313 0 0 0>
            , <&key_physical_attrs 100 100  900  300 0 0 0>
            , <&key_physical_attrs 100 100 1000  308 0 0 0>
            , <&key_physical_attrs 100 100 1100  326 0 0 0>
            , <&key_physical_attrs 100 100 1200  326 0 0 0>

            , <&key_physical_attrs 100 100  300  440 0 0 0>
            , <&key_physical_attrs 100 100  400  450 0 0 0>
            , <&key_physical_attrs 100 100  500  455 0 0 0>
            , <&key_physical_attrs 100 100  700  455 0 0 0>
            , <&key_physical_attrs 100 100  800  450 0 0 0>
            , <&key_physical_attrs 100 100  900  440 0 0 0>
            ;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";

        col-gpios
            = <&gpio0  2 GPIO_ACTIVE_HIGH>   /* COL0: P0.02 */
            , <&gpio0  3 GPIO_ACTIVE_HIGH>   /* COL1: P0.03 */
            , <&gpio0 28 GPIO_ACTIVE_HIGH>   /* COL2: P0.28 */
            , <&gpio0 29 GPIO_ACTIVE_HIGH>   /* COL3: P0.29 */
            , <&gpio0  4 GPIO_ACTIVE_HIGH>   /* COL4: P0.04 */
            , <&gpio0  5 GPIO_ACTIVE_HIGH>   /* COL5: P0.05 */
            ;

        row-gpios
            = <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW0: P1.11 */
            , <&gpio1 12 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW1: P1.12 */
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW2: P1.13 */
            , <&gpio1 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW3: P1.14 */
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW4: P1.15 */
            ;
    };
};

/*
 * 外付けQSPIフラッシュ(P25Q16H)を無効化。
 * このチップはディープパワーダウンからの復帰がQSPIドライバのバグで失敗し、
 * 「スリープから復帰しない」＆「スリープ電流が大きく電池を食う」原因になる。
 * ZMKは内蔵フラッシュだけで動作する（設定/ペアリング保存も内蔵側）ため、無効化して問題なし。
 */
&qspi {
    status = "disabled";
};
